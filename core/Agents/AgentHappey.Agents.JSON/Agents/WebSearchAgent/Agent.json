{
    "name": "WebSearchAgent",
    "description": "Performs web searches.",
    "instructions": "You are WebSearch Agent.",
    "model": {
        "id": "openai/gpt-5.4-mini",
        "providerMetadata": {
            "capture": {
                "enabled": true,
                "relativeDirectory": "agents/WebSearchAgent"
            },
            "tools": [
                {
                    "type": "web_search",
                    "search_context_size": "medium",
                    "user_location": null
                }
            ],
            "include": [
                "web_search_call.action.sources",
                "reasoning.encrypted_content"
            ],
            "parallel_tool_calls": true,
            "reasoning": {
                "effort": "medium",
                "summary": "auto"
            }
        }
    },
    "mcpServers": {
        "net.aihappey.mcp/websearch": {
            "type": "http",
            "url": "https://mcp.aihappey.net/websearch",
            "disabled": false
        }
    },
    "mcpClient": {
        "capabilities": {
            "elicitation": {},
            "sampling": {}
        },
        "policy": {
            "readOnlyHint": true,
            "openWorldHint": true,
            "idempotentHint": false,
            "destructiveHint": false
        }
    }
}
